# Copy this file to .env and fill in your keys.
# All keys are OPTIONAL — sources without keys are skipped gracefully.
# The server will tell you at startup which sources are active.

# --- Google Search, Maps, Images (highest ROI) ---
# Free 100/mo. $50/mo → 5k searches. https://serpapi.com
SERPAPI_KEY=

# --- Email finder by name + domain ---
# Free 25/mo. $49/mo → 500. https://hunter.io
HUNTER_API_KEY=

# --- LinkedIn profile data (photo, title, current company) ---
# RapidAPI "Fresh LinkedIn Profile Data". ~$10/mo.
# https://rapidapi.com/freshdata-freshdata-default/api/fresh-linkedin-profile-data
RAPIDAPI_KEY=

# --- People Data Labs (best bulk enrichment) ---
# 100 free credits. $0.10-0.20/match.
# https://peopledatalabs.com
PDL_API_KEY=

# --- Server config ---
PORT=3001
CACHE_TTL_DAYS=30
MAX_BATCH_CONCURRENCY=3
# Set to a shared secret if you want to require Authorization: Bearer <token>
# Leave blank for local-only development.
API_AUTH_TOKEN=
